generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  createdAt  DateTime @default(now())
}

model Category {
  id         String      @id @default(uuid())
  name       String      @unique
  articles   Article[]
  newsEvents NewsEvent[]
}

model NewsSource {
  id            String    @id @default(uuid())
  name          String
  rssUrl        String    @unique
  categoryName  String
  isActive      Boolean   @default(true)
  lastFetchedAt DateTime?
  createdAt     DateTime  @default(now())
  articles      Article[]
}

/// Represents a canonical news event that clusters multiple articles covering the same story.
model NewsEvent {
  id           String    @id @default(uuid())
  title        String
  summary      String?
  articleCount Int       @default(1)
  firstSeenAt  DateTime
  lastSeenAt   DateTime
  categoryId   String
  category     Category  @relation(fields: [categoryId], references: [id])
  embedding    Float[]   /// 768-dim centroid vector for the event cluster
  articles     Article[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Article {
  id               String      @id @default(uuid())
  title            String
  summary          String?
  content          String
  url              String      @unique
  source           String
  externalId       String?     @unique
  isTopStory       Boolean     @default(false)
  isTopDevelopment Boolean     @default(false)

  categoryId       String
  category         Category    @relation(fields: [categoryId], references: [id])

  sourceId         String?
  newsSource       NewsSource? @relation(fields: [sourceId], references: [id])

  embedding        Float[]     /// 768-dim embedding vector from Gemini text-embedding-004
  eventId          String?
  newsEvent        NewsEvent?  @relation(fields: [eventId], references: [id])

  publishedAt      DateTime
  createdAt        DateTime    @default(now())
}

